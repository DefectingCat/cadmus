{
  "name": "cadmus-frontend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outdir=../static/dist --minify --format=esm",
    "build:editor": "esbuild src/editor/index.ts --bundle --outdir=../static/dist/editor.js --minify",
    "build:admin-media": "esbuild src/admin/media/index.ts --bundle --outdir=../static/dist/admin-media.js --minify",
    "build:admin-comments": "esbuild src/admin/comments/list.ts --bundle --outdir=../static/dist/admin/comments.js --minify",
    "build:css": "bunx @tailwindcss/cli -i src/styles/main.css -o ../static/dist/styles.css --minify",
    "dev": "esbuild src/main.ts --bundle --outdir=../static/dist --watch --sourcemap=inline --format=esm",
    "dev:css": "bunx @tailwindcss/cli -i src/styles/main.css -o ../static/dist/styles.css --watch",
    "typecheck": "tsc --noEmit",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "@tailwindcss/cli": "^4.2.2"
  }
}