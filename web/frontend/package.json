{
  "name": "cadmus-frontend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build:all": "bun run build && bun run build:admin && bun run build:admin-posts && bun run build:admin-post-edit && bun run build:admin-media && bun run build:admin-comments && bun run build:css && bun run build:admin-css",
    "build": "bunx esbuild src/main.ts --bundle --outdir=../static/dist --minify --format=esm",
    "build:editor": "bunx esbuild src/editor/index.ts --bundle --outfile=../static/dist/editor.js --minify",
    "build:admin": "bunx esbuild src/admin/main.ts --bundle --outfile=../static/dist/admin/main.js --minify --format=esm",
    "build:admin-posts": "bunx esbuild src/admin/posts/list.ts --bundle --outfile=../static/dist/admin/posts.js --minify",
    "build:admin-post-edit": "bunx esbuild src/admin/posts/editor.ts --bundle --outfile=../static/dist/admin/post-edit.js --minify",
    "build:admin-media": "bunx esbuild src/admin/media/index.ts --bundle --outfile=../static/dist/admin-media.js --minify",
    "build:admin-comments": "bunx esbuild src/admin/comments/list.ts --bundle --outfile=../static/dist/admin/comments.js --minify",
    "build:css": "bunx @tailwindcss/cli -i src/styles/main.css -o ../static/dist/styles.css --minify",
    "build:admin-css": "bunx @tailwindcss/cli -i src/styles/admin.css -o ../static/dist/admin.css --minify",
    "dev": "bunx esbuild src/main.ts --bundle --outdir=../static/dist --watch --sourcemap=inline --format=esm",
    "dev:css": "bunx @tailwindcss/cli -i src/styles/main.css -o ../static/dist/styles.css --watch",
    "typecheck": "tsc --noEmit",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "@tailwindcss/cli": "^4.2.2"
  }
}